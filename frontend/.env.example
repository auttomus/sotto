# ─── BACKEND & API SERVICES ──────────────────────────────────────────────────
# URL endpoint GraphQL (Apollo Client) untuk komunikasi data utama.
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# URL endpoint REST IAM untuk autentikasi (login, register).
VITE_IAM_BASE_URL=http://localhost:3000/iam

# URL WebSocket (Socket.io) untuk sinkronisasi chat real-time.
VITE_WS_URL=ws://localhost:3000

# ─── OBJECT STORAGE (MINIO / CLOUDFLARE R2) ─────────────────────────────────
# URL publik akses file media (avatar, gambar postingan, thumbnail listing).
# - MinIO Lokal: http://localhost:9000/public-assets
# - Cloudflare R2: https://cdn.sotto.auttomus.xyz
VITE_MINIO_PUBLIC_URL=http://localhost:9000/public-assets

# ─── MIDTRANS (PAYMENT GATEWAY) ─────────────────────────────────────────────
# Client Key Midtrans Sandbox untuk menginisialisasi pembayaran di sisi client.
VITE_MIDTRANS_CLIENT_KEY=your_midtrans_client_key_here
