# Sotto Frontend — Environment Variables
# Copy this file to .env and fill in the values.

# GraphQL API endpoint (Apollo Client)
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# WebSocket endpoint for real-time chat (Socket.io)
VITE_WS_URL=ws://localhost:3000

# MinIO public URL for serving media assets (avatars, post images, listing thumbnails)
VITE_MINIO_PUBLIC_URL=https://your-public-bucket-url.r2.dev

# IAM REST base URL for auth endpoints (login, register)
VITE_IAM_BASE_URL=http://localhost:3000/iam
