meta {
  name: My Profile
  type: graphql
  seq: 1
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    myProfile {
      id
      username
      displayName
      major
      note
      avatarObjectKey
      followersCount
      followingCount
      trustScore
      schoolName
      createdAt
      updatedAt
    }
  }
}
