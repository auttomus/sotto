meta {
  name: Get Profile by Username (Public)
  type: graphql
  seq: 2
}

post {
  url: {{gql_url}}
  body: graphql
  auth: none
}

body:graphql {
  query {
    profile(username: "arya_pranata") {
      id
      username
      displayName
      major
      note
      followersCount
      followingCount
      trustScore
      schoolName
      createdAt
      updatedAt
      isFollowing
    }
  }
}
