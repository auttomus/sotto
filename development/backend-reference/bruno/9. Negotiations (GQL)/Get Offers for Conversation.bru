meta {
  name: Get Offers for Conversation
  type: graphql
  seq: 2
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    offersForConversation(conversationId: "{{conversation_id}}") {
      id
      description
      proposedPrice
      deliveryTimeDays
      status
      expiresAt
      createdAt
      updatedAt
    }
  }
}
