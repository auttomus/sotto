meta {
  name: Get Post by ID
  type: graphql
  seq: 3
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    post(postId: "{{last_post_id}}") {
      postId
      authorId
      authorUsername
      authorDisplayName
      authorAvatarObjectKey
      authorSchoolName
      content
      createdAt
      media {
        url
        contentType
      }
      tags {
        name
      }
      likesCount
      repliesCount
    }
  }
}
