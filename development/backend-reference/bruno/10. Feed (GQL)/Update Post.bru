meta {
  name: Update Post
  type: graphql
  seq: 9
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  mutation {
    updatePost(
      postId: "{{last_post_id}}",
      input: {
        content: "Ini postingan yang baru saja saya update!",
        tagIds: []
      }
    ) {
      postId
      content
      createdAt
    }
  }
}
