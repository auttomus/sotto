meta {
  name: Get Messages
  type: graphql
  seq: 3
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    messages(conversationId: "{{conversation_id}}", limit: 50) {
      messageId
      senderId
      content
      createdAt
      media {
        url
        contentType
      }
    }
  }
}
