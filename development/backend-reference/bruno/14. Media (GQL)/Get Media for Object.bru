meta {
  name: Get Media for Object
  type: graphql
  seq: 3
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    mediaForObject(attachedType: "ScyllaPost", attachedId: "{{last_post_id}}") {
      id
      fileName
      contentType
      objectKey
      url
      isPrivate
      createdAt
    }
  }
}
