meta {
  name: Search Listings
  type: graphql
  seq: 1
}

post {
  url: {{gql_url}}
  body: graphql
  auth: none
}

body:graphql {
  query {
    searchListings(query: "website") {
      id
      title
      price
      type
      status
      account {
        displayName
        trustScore
      }
    }
  }
}
