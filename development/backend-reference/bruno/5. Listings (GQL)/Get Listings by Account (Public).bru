meta {
  name: Get Listings by Account (Public)
  type: graphql
  seq: 5
}

post {
  url: {{gql_url}}
  body: graphql
  auth: none
}

body:graphql {
  query {
    listingsByAccount(accountId: "{{account_id}}") {
      id
      title
      price
      status
      media {
        id
        url
      }
    }
  }
}
