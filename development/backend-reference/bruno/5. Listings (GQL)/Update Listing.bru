meta {
  name: Update Listing
  type: graphql
  seq: 2
}

post {
  url: {{gql_url}}
  body: graphql
  auth: inherit
}

body:graphql {
  mutation {
    updateListing(id: "{{listing_id}}", input: {
      title: "Jasa Website Premium",
      basePrice: 200000
    }) {
      id
      title
      price
      updatedAt
    }
  }
}
