              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"jwt_token\", jsonData.accessToken);",
                  "    console.log(\"Token JWT berhasil ditangkap dan disimpan ke environment!\");",
