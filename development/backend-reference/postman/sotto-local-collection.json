      "name": "1. IAM (REST)",
      "item": [
        {
          "name": "Register [201]",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arya.pranata@smkn1denpasar.sch.id\",\n  \"password\": \"RplSotto2026!\",\n  \"username\": \"arya_pranata_dev\",\n  \"displayName\": \"Kadek Agus Arya P.\",\n  \"schoolId\": 1,\n  \"major\": \"Rekayasa Perangkat Lunak\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/iam/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "iam",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login [200] Auto-Set Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if(pm.response.code===200){var d=pm.response.json();pm.environment.set('jwt_token',d.accessToken);pm.environment.set('account_id',d.accountId||'');console.log('Token saved!');}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arya.pranata@smkn1denpasar.sch.id\",\n  \"password\": \"RplSotto2026!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/iam/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "iam",
                "login"
              ]
            }
          }
        },
        {
          "name": "Login [401] Wrong Password",
