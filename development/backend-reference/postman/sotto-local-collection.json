              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"arya.pranata@smkn1denpasar.sch.id\",\n  \"password\": \"WrongPass!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/iam/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "iam",
                "login"
              ]
            }
          }
        }
