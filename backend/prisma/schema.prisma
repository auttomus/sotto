generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================
enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ConversationType {
  DIRECT
  GROUP
  ORDER
}

enum NotificationType {
  FOLLOW
  ORDER_UPDATE
  NEW_MESSAGE
  MENTION
}

enum ListingType {
  SERVICE
  DIGITAL_PRODUCT
}

// ==========================================
// 1. IDENTITY & PUBLIC PERSONA
// ==========================================

model User {
  id                BigInt   @id @default(autoincrement())
  accountId         BigInt   @unique @map("account_id") //
  email             String   @unique
  encryptedPassword String   @map("encrypted_password") //
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Account {
  id          BigInt @id @default(autoincrement())
  username    String @unique
  displayName String @map("display_name")

  schoolId BigInt? @map("school_id")
  major    String? //[cite: 1]

  note            String? @db.Text //[cite: 1]
  avatarObjectKey String? @map("avatar_object_key") //[cite: 1]

  followersCount BigInt  @default(0) @map("followers_count") //[cite: 1]
  followingCount BigInt  @default(0) @map("following_count") //[cite: 1]
  trustScore     Decimal @default(0.0) @map("trust_score") @db.Decimal(3, 2) //[cite: 1]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user                   User?
  school                 School?                   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  listings               Listing[]
  ordersAsBuyer          Order[]                   @relation("BuyerOrders")
  ordersAsSeller         Order[]                   @relation("SellerOrders")
  reviewsGiven           Review[]                  @relation("Reviewer")
  reviewsReceived        Review[]                  @relation("Reviewee")
  followers              Follow[]                  @relation("Following")
  following              Follow[]                  @relation("Follower")
  conversationParts      ConversationParticipant[]
  notifications          Notification[]            @relation("NotificationReceiver")
  notificationsTriggered Notification[]            @relation("NotificationTrigger")
  customOffersSent       CustomOffer[]             @relation("OfferSender")
  customOffersReceived   CustomOffer[]             @relation("OfferReceiver")
  mediaAttachments       MediaAttachment[]

  @@map("accounts")
}

// ==========================================
// 2. THE GIG ECONOMY
// ==========================================

model Listing {
  id        BigInt @id @default(autoincrement())
  accountId BigInt @map("account_id")

  type             ListingType @default(SERVICE) //[cite: 1]
  title            String
  description      String      @db.Text
  price            Decimal     @db.Decimal(12, 2)
  deliveryTimeDays Int?        @map("delivery_time_days") //[cite: 1]

  maxActiveOrders Int?    @map("max_active_orders") //[cite: 1]
  isUnlimited     Boolean @default(false) @map("is_unlimited") //[cite: 1]

  status      ListingStatus @default(ACTIVE) //[cite: 1]
  lockVersion Int           @default(0) @map("lock_version") //[cite: 1]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orders       Order[]
  customOffers CustomOffer[]

  @@map("listings")
}

model Order {
  id              BigInt  @id @default(autoincrement())
  buyerAccountId  BigInt  @map("buyer_account_id") //[cite: 1]
  sellerAccountId BigInt  @map("seller_account_id") //[cite: 1]
  listingId       BigInt  @map("listing_id") // Sesuai instruksi DBML koreksi dari service_id[cite: 1]
  customOfferId   BigInt? @unique @map("custom_offer_id") //[cite: 1]

  agreedPrice Decimal     @map("agreed_price") @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING_PAYMENT)

  lockVersion Int @default(0) @map("lock_version") // OPTIMISTIC LOCKING[cite: 1]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer        Account       @relation("BuyerOrders", fields: [buyerAccountId], references: [id], onDelete: Restrict)
  seller       Account       @relation("SellerOrders", fields: [sellerAccountId], references: [id], onDelete: Restrict)
  listing      Listing       @relation(fields: [listingId], references: [id], onDelete: Restrict)
  customOffer  CustomOffer?  @relation(fields: [customOfferId], references: [id], onDelete: Restrict)
  review       Review?
  conversation Conversation?

  @@map("orders")
}

model Review {
  id                BigInt  @id @default(autoincrement())
  orderId           BigInt  @unique @map("order_id")
  reviewerAccountId BigInt  @map("reviewer_account_id")
  targetAccountId   BigInt  @map("target_account_id")
  rating            Int     @db.SmallInt
  comment           String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at") // <-- INI TAMBAHANNYA

  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer Account @relation("Reviewer", fields: [reviewerAccountId], references: [id], onDelete: Cascade)
  target   Account @relation("Reviewee", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ==========================================
// 3. SOCIAL GRAPH
// ==========================================

model Follow {
  id              BigInt   @id @default(autoincrement()) //[cite: 1]
  accountId       BigInt   @map("account_id") //[cite: 1]
  targetAccountId BigInt   @map("target_account_id") //[cite: 1]
  createdAt       DateTime @default(now()) @map("created_at")

  follower  Account @relation("Following", fields: [accountId], references: [id], onDelete: Cascade)
  following Account @relation("Follower", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@unique([accountId, targetAccountId]) //[cite: 1]
  @@map("follows")
}

// ==========================================
// 4. CHAT METADATA
// ==========================================

model Conversation {
  id      BigInt           @id @default(autoincrement())
  type    ConversationType @default(DIRECT)
  orderId BigInt?          @unique @map("order_id") //[cite: 1]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order        Order?                    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  customOffers CustomOffer[]

  @@map("conversations")
}

model ConversationParticipant {
  id                BigInt   @id @default(autoincrement()) //[cite: 1]
  conversationId    BigInt   @map("conversation_id")
  accountId         BigInt   @map("account_id")
  lastReadMessageId String?  @map("last_read_message_id") @db.VarChar // TimeUUID string dari ScyllaDB[cite: 1]
  joinedAt          DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([conversationId, accountId]) //[cite: 1]
  @@index([accountId]) //[cite: 1]
  @@map("conversation_participants")
}

// ==========================================
// 5. MEDIA & ASSET MANAGER (MINIO)
// ==========================================

model MediaAttachment {
  id        BigInt @id @default(autoincrement())
  accountId BigInt @map("account_id")

  // Polymorphic Handling
  attachedType String @map("attached_type") //[cite: 1]
  attachedId   String @map("attached_id") //[cite: 1]

  fileName    String  @map("file_name") //[cite: 1]
  contentType String  @map("content_type") //[cite: 1]
  fileSize    BigInt  @map("file_size") //[cite: 1]
  blurhash    String? //[cite: 1]

  bucketName String  @default("public-assets") @map("bucket_name") //[cite: 1]
  objectKey  String  @unique @map("object_key") //[cite: 1]
  isPrivate  Boolean @default(false) @map("is_private") //[cite: 1]

  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId]) //[cite: 1]
  @@index([attachedType, attachedId]) //[cite: 1]
  @@map("media_attachments")
}

// ==========================================
// 6. CATEGORIZATION & NOTIFICATIONS
// ==========================================

model Tag {
  id        BigInt   @id @default(autoincrement())
  name      String   @unique //[cite: 1]
  isUsable  Boolean  @default(true) @map("is_usable") //[cite: 1]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tags")
}

model TaggedObject {
  id         BigInt @id @default(autoincrement()) //[cite: 1]
  tagId      BigInt @map("tag_id")
  objectId   String @map("object_id") // Polymorphic (Bisa ke UUID ScyllaDB)[cite: 1]
  objectType String @map("object_type") //[cite: 1]

  @@unique([objectType, objectId, tagId]) //[cite: 1]
  @@index([tagId]) //[cite: 1]
  @@map("tagged_objects")
}

model Notification {
  id            BigInt  @id @default(autoincrement())
  accountId     BigInt  @map("account_id") //[cite: 1]
  fromAccountId BigInt? @map("from_account_id") //[cite: 1]

  type       NotificationType //[cite: 1]
  targetType String?          @map("target_type") // Polymorphic[cite: 1]
  targetId   String?          @map("target_id") // Polymorphic[cite: 1]

  isRead    Boolean  @default(false) @map("is_read") //[cite: 1]
  createdAt DateTime @default(now()) @map("created_at")

  account     Account  @relation("NotificationReceiver", fields: [accountId], references: [id], onDelete: Cascade)
  fromAccount Account? @relation("NotificationTrigger", fields: [fromAccountId], references: [id], onDelete: SetNull)

  @@index([accountId]) //[cite: 1]
  @@index([accountId, isRead]) // Sangat cepat untuk aggregate "Unread"[cite: 1]
  @@map("notifications")
}

model School {
  id         BigInt   @id @default(autoincrement())
  npsn       String   @unique //[cite: 1]
  name       String //[cite: 1]
  domain     String?  @unique //[cite: 1]
  city       String? //[cite: 1]
  isVerified Boolean  @default(false) @map("is_verified") //[cite: 1]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("schools")
}

// ==========================================
// 7. PRE-SALES / NEGOTIATION
// ==========================================

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model CustomOffer {
  id              BigInt  @id @default(autoincrement())
  conversationId  BigInt  @map("conversation_id") //[cite: 1]
  sellerAccountId BigInt  @map("seller_account_id") //[cite: 1]
  buyerAccountId  BigInt  @map("buyer_account_id") //[cite: 1]
  listingId       BigInt? @map("listing_id") //[cite: 1]

  description      String      @db.Text //[cite: 1]
  proposedPrice    Decimal     @map("proposed_price") @db.Decimal(12, 2) //[cite: 1]
  deliveryTimeDays Int         @map("delivery_time_days") //[cite: 1]
  status           OfferStatus @default(PENDING) //[cite: 1]
  expiresAt        DateTime?   @map("expires_at") //[cite: 1]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  seller       Account      @relation("OfferSender", fields: [sellerAccountId], references: [id], onDelete: Restrict)
  buyer        Account      @relation("OfferReceiver", fields: [buyerAccountId], references: [id], onDelete: Restrict)
  listing      Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  order        Order?

  @@index([conversationId]) //[cite: 1]
  @@index([buyerAccountId]) //[cite: 1]
  @@map("custom_offers")
}
