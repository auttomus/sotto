generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================
enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum OrderStatus {
  PENDING_PAYMENT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ConversationType {
  DIRECT
  GROUP
  ORDER
}

enum NotificationType {
  FOLLOW
  ORDER_UPDATE
  NEW_MESSAGE
  MENTION
}

enum ListingType {
  SERVICE
  DIGITAL_PRODUCT
}

// ==========================================
// 1. IDENTITY & PUBLIC PERSONA
// ==========================================

model User {
  id                String   @id @default(uuid(7)) @db.Uuid
  accountId         String   @unique @map("account_id") @db.Uuid
  email             String   @unique
  encryptedPassword String   @map("encrypted_password")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Account {
  id          String @id @default(uuid(7)) @db.Uuid
  username    String @unique
  displayName String @map("display_name")

  schoolId String? @map("school_id") @db.Uuid
  major    String?

  note            String? @db.Text
  avatarObjectKey String? @map("avatar_object_key")

  followersCount BigInt  @default(0) @map("followers_count")
  followingCount BigInt  @default(0) @map("following_count")
  trustScore     Decimal @default(0.0) @map("trust_score") @db.Decimal(3, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user                   User?
  school                 School?                   @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  listings               Listing[]
  ordersAsBuyer          Order[]                   @relation("BuyerOrders")
  ordersAsSeller         Order[]                   @relation("SellerOrders")
  reviewsGiven           Review[]                  @relation("Reviewer")
  reviewsReceived        Review[]                  @relation("Reviewee")
  followers              Follow[]                  @relation("Following")
  following              Follow[]                  @relation("Follower")
  conversationParts      ConversationParticipant[]
  notifications          Notification[]            @relation("NotificationReceiver")
  notificationsTriggered Notification[]            @relation("NotificationTrigger")
  customOffersSent       CustomOffer[]             @relation("OfferSender")
  customOffersReceived   CustomOffer[]             @relation("OfferReceiver")
  mediaAttachments       MediaAttachment[]

  @@map("accounts")
}

// ==========================================
// 2. THE GIG ECONOMY
// ==========================================

model Listing {
  id        String @id @default(uuid(7)) @db.Uuid
  accountId String @map("account_id") @db.Uuid

  type             ListingType @default(SERVICE)
  title            String
  description      String      @db.Text
  price            Decimal     @db.Decimal(12, 2)
  deliveryTimeDays Int?        @map("delivery_time_days")

  maxActiveOrders Int?    @map("max_active_orders")
  isUnlimited     Boolean @default(false) @map("is_unlimited")

  status      ListingStatus @default(ACTIVE)
  lockVersion Int           @default(0) @map("lock_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  orders       Order[]
  customOffers CustomOffer[]

  @@map("listings")
}

model Order {
  id              String  @id @default(uuid(7)) @db.Uuid
  buyerAccountId  String  @map("buyer_account_id") @db.Uuid
  sellerAccountId String  @map("seller_account_id") @db.Uuid
  listingId       String  @map("listing_id") @db.Uuid
  customOfferId   String? @unique @map("custom_offer_id") @db.Uuid

  agreedPrice Decimal     @map("agreed_price") @db.Decimal(12, 2)
  status      OrderStatus @default(PENDING_PAYMENT)

  lockVersion Int @default(0) @map("lock_version")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer        Account       @relation("BuyerOrders", fields: [buyerAccountId], references: [id], onDelete: Restrict)
  seller       Account       @relation("SellerOrders", fields: [sellerAccountId], references: [id], onDelete: Restrict)
  listing      Listing       @relation(fields: [listingId], references: [id], onDelete: Restrict)
  customOffer  CustomOffer?  @relation(fields: [customOfferId], references: [id], onDelete: Restrict)
  review       Review?
  conversation Conversation?

  @@map("orders")
}

model Review {
  id                String  @id @default(uuid(7)) @db.Uuid
  orderId           String  @unique @map("order_id") @db.Uuid
  reviewerAccountId String  @map("reviewer_account_id") @db.Uuid
  targetAccountId   String  @map("target_account_id") @db.Uuid
  rating            Int     @db.SmallInt
  comment           String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order    Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer Account @relation("Reviewer", fields: [reviewerAccountId], references: [id], onDelete: Cascade)
  target   Account @relation("Reviewee", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

// ==========================================
// 3. SOCIAL GRAPH
// ==========================================

model Follow {
  id              String   @id @default(uuid(7)) @db.Uuid
  accountId       String   @map("account_id") @db.Uuid
  targetAccountId String   @map("target_account_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  follower  Account @relation("Following", fields: [accountId], references: [id], onDelete: Cascade)
  following Account @relation("Follower", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@unique([accountId, targetAccountId])
  @@map("follows")
}

// ==========================================
// 4. CHAT METADATA
// ==========================================

model Conversation {
  id      String           @id @default(uuid(7)) @db.Uuid
  type    ConversationType @default(DIRECT)
  orderId String?          @unique @map("order_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order        Order?                    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  customOffers CustomOffer[]

  @@map("conversations")
}

model ConversationParticipant {
  id                String   @id @default(uuid(7)) @db.Uuid
  conversationId    String   @map("conversation_id") @db.Uuid
  accountId         String   @map("account_id") @db.Uuid
  lastReadMessageId String?  @map("last_read_message_id") @db.VarChar
  joinedAt          DateTime @default(now()) @map("joined_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([conversationId, accountId])
  @@index([accountId])
  @@map("conversation_participants")
}

// ==========================================
// 5. MEDIA & ASSET MANAGER (MINIO)
// ==========================================

model MediaAttachment {
  id        String @id @default(uuid(7)) @db.Uuid
  accountId String @map("account_id") @db.Uuid

  // Polymorphic Handling
  attachedType String @map("attached_type")
  attachedId   String @map("attached_id")

  fileName    String  @map("file_name")
  contentType String  @map("content_type")
  fileSize    BigInt  @map("file_size")
  blurhash    String?

  bucketName String  @default("public-assets") @map("bucket_name")
  objectKey  String  @unique @map("object_key")
  isPrivate  Boolean @default(false) @map("is_private")

  createdAt DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([attachedType, attachedId])
  @@map("media_attachments")
}

// ==========================================
// 6. CATEGORIZATION & NOTIFICATIONS
// ==========================================

model Tag {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String   @unique
  isUsable  Boolean  @default(true) @map("is_usable")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("tags")
}

model TaggedObject {
  id         String @id @default(uuid(7)) @db.Uuid
  tagId      String @map("tag_id") @db.Uuid
  objectId   String @map("object_id")
  objectType String @map("object_type")

  @@unique([objectType, objectId, tagId])
  @@index([tagId])
  @@map("tagged_objects")
}

model Notification {
  id            String  @id @default(uuid(7)) @db.Uuid
  accountId     String  @map("account_id") @db.Uuid
  fromAccountId String? @map("from_account_id") @db.Uuid

  type       NotificationType
  targetType String?          @map("target_type")
  targetId   String?          @map("target_id")

  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  account     Account  @relation("NotificationReceiver", fields: [accountId], references: [id], onDelete: Cascade)
  fromAccount Account? @relation("NotificationTrigger", fields: [fromAccountId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([accountId, isRead])
  @@map("notifications")
}

model School {
  id         String   @id @default(uuid(7)) @db.Uuid
  npsn       String   @unique
  name       String
  domain     String?  @unique
  city       String?
  isVerified Boolean  @default(false) @map("is_verified")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  accounts Account[]

  @@map("schools")
}

// ==========================================
// 7. PRE-SALES / NEGOTIATION
// ==========================================

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model CustomOffer {
  id              String  @id @default(uuid(7)) @db.Uuid
  conversationId  String  @map("conversation_id") @db.Uuid
  sellerAccountId String  @map("seller_account_id") @db.Uuid
  buyerAccountId  String  @map("buyer_account_id") @db.Uuid
  listingId       String? @map("listing_id") @db.Uuid

  description      String      @db.Text
  proposedPrice    Decimal     @map("proposed_price") @db.Decimal(12, 2)
  deliveryTimeDays Int         @map("delivery_time_days")
  status           OfferStatus @default(PENDING)
  expiresAt        DateTime?   @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  seller       Account      @relation("OfferSender", fields: [sellerAccountId], references: [id], onDelete: Restrict)
  buyer        Account      @relation("OfferReceiver", fields: [buyerAccountId], references: [id], onDelete: Restrict)
  listing      Listing?     @relation(fields: [listingId], references: [id], onDelete: SetNull)
  order        Order?

  @@index([conversationId])
  @@index([buyerAccountId])
  @@map("custom_offers")
}
