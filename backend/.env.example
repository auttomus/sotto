# ─── DATABASE (POSTGRESQL) ──────────────────────────────────────────────────
# Kredensial untuk database transaksional PostgreSQL.
# DATABASE_URL digunakan oleh Prisma ORM untuk melakukan migrasi dan query.
POSTGRES_USER=platform_admin
POSTGRES_PASSWORD=supersecret_dev_password
POSTGRES_DB=sotto_platform_db
DATABASE_URL="postgresql://platform_admin:supersecret_dev_password@localhost:5432/sotto_platform_db?schema=public"

# ─── SCYLLADB ───────────────────────────────────────────────────────────────
# Alamat contact points dan keyspace ScyllaDB untuk performa tinggi (data chat/pesan).
SCYLLA_CONTACT_POINTS=localhost:9042
SCYLLA_KEYSPACE=sotto
SCYLLA_DATACENTER=datacenter1

# ─── REDIS ──────────────────────────────────────────────────────────────────
# URL koneksi untuk server Redis (digunakan untuk caching, session, dan antrean BullMQ).
REDIS_URL=redis://localhost:6379

# ─── OBJECT STORAGE (MINIO / CLOUDFLARE R2) ─────────────────────────────────
# Konfigurasi S3-compatible Object Storage untuk media (avatar, gambar postingan, dll).
# - Endpoint R2: <account_id>.r2.cloudflarestorage.com (Kosongkan port & set SSL ke true)
# - Endpoint MinIO Lokal: localhost (Port 9000, set SSL ke false)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin_minio
MINIO_SECRET_KEY=supersecret_minio_password
MINIO_BUCKET_PUBLIC=public-assets
MINIO_BUCKET_PRIVATE=private-assets

# Alamat URL akses publik ke aset (CDN).
# - MinIO Lokal: http://localhost:9000
# - Cloudflare R2: https://cdn.sotto.auttomus.xyz (atau subdomain R2.dev Anda)
MINIO_PUBLIC_URL=http://localhost:9000

# ─── MIDTRANS (PAYMENT GATEWAY) ─────────────────────────────────────────────
# Kredensial API Midtrans Sandbox untuk pemrosesan pembayaran simulasi.
MIDTRANS_SERVER_KEY="masukkan_server_key_anda"
MIDTRANS_CLIENT_KEY="masukkan_client_key_anda"

# ─── NGROK (WEBHOOK TUNNEL) ─────────────────────────────────────────────────
# Endpoint API Ngrok lokal untuk autodiscovery URL webhook Midtrans secara dinamis.
# - Di Host OS: http://localhost:4040/api/tunnels
# - Di dalam Docker: http://ngrok:4040/api/tunnels
NGROK_API_URL=http://localhost:4040/api/tunnels

# ─── JWT & AUTHENTICATION ───────────────────────────────────────────────────
# Kunci rahasia untuk tanda tangan digital JSON Web Token.
JWT_SECRET=sotto_super_secret_key_2026

# ─── FRONTEND & CORS ────────────────────────────────────────────────────────
# Domain asal aplikasi frontend untuk izin CORS.
FRONTEND_URL=http://localhost:5173

# ─── SYNERGY RECOMMENDATION ENGINE ──────────────────────────────────────────
# Hyperparameter untuk algoritma pemeringkatan feed rekomendasi Sotto.
SYNERGY_ALPHA=0.6
SYNERGY_BETA=0.1
SYNERGY_GAMMA=0.3
SYNERGY_LAMBDA_G=0.5
SYNERGY_LAMBDA_T=0.0577          # 12-hour half-life untuk penurunan kualitas dasar
SYNERGY_FRESHNESS_BOOST=0.5      # Kekuatan dorongan kebaruan untuk postingan baru
SYNERGY_FRESHNESS_DECAY=0.3466    # 2-hour half-life untuk peluruhan dorongan kebaruan