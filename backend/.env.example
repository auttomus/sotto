DATABASE_USER=test
DATABASE_PASSWORD=test

# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://platform_admin:supersecret_dev_password@localhost:5432/sotto_platform_db?schema=public"

# ==========================================
# JWT & AUTH
# ==========================================
JWT_SECRET=sotto_super_secret_key_2026

# ==========================================
# FRONTEND (CORS)
# ==========================================
FRONTEND_URL=http://localhost:5173

# ==========================================
# REDIS
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# SCYLLADB
# ==========================================
SCYLLA_CONTACT_POINTS=localhost:9042
SCYLLA_KEYSPACE=sotto
SCYLLA_DATACENTER=datacenter1

# ==========================================
# MINIO (S3-Compatible Object Storage)
# ==========================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin_minio
MINIO_SECRET_KEY=supersecret_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET_PUBLIC=public-assets
MINIO_BUCKET_PRIVATE=private-assets

# ==========================================
# SYNERGY ENGINE HYPERPARAMETERS
# ==========================================
SYNERGY_ALPHA=0.6
SYNERGY_BETA=0.1
SYNERGY_GAMMA=0.3
SYNERGY_LAMBDA_G=0.5
SYNERGY_LAMBDA_T=0.0288