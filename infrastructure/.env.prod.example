# ─── DATABASE (POSTGRESQL) ──────────────────────────────────────────────────
# Kredensial PostgreSQL tingkat produksi.
# DATABASE_URL menggunakan host 'postgres' (nama service di docker-compose).
POSTGRES_USER=sotto_prod_admin
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=sotto_production_db
DATABASE_URL="postgresql://sotto_prod_admin:your_secure_db_password_here@postgres:5432/sotto_production_db?schema=public"

# ─── SCYLLADB ───────────────────────────────────────────────────────────────
# Alamat contact points dan keyspace ScyllaDB tingkat produksi.
SCYLLA_CONTACT_POINTS=scylladb:9042
SCYLLA_KEYSPACE=sotto
SCYLLA_DATACENTER=datacenter1

# ─── REDIS ──────────────────────────────────────────────────────────────────
# URL koneksi Redis tingkat produksi.
REDIS_URL=redis://redis:6379

# ─── OBJECT STORAGE (MINIO / CLOUDFLARE R2) ─────────────────────────────────
# Konfigurasi Cloudflare R2 atau S3-Compatible Object Storage tingkat produksi.
# Omit atau kosongkan port untuk R2 (otomatis menggunakan port HTTPS 443).
MINIO_ENDPOINT=your_cloudflare_account_id.r2.cloudflarestorage.com
MINIO_PORT=
MINIO_USE_SSL=true
MINIO_REGION=auto
MINIO_ACCESS_KEY=your_r2_s3_api_access_key
MINIO_SECRET_KEY=your_r2_s3_api_secret_key
MINIO_BUCKET_PUBLIC=sotto-public-assets
MINIO_BUCKET_PRIVATE=sotto-private-assets

# Alamat URL akses publik/CDN ke aset (subdomain R2.dev atau domain kustom).
MINIO_PUBLIC_URL=https://your_r2_public_url_or_subdomain.r2.dev
VITE_MINIO_PUBLIC_URL=https://your_r2_public_url_or_subdomain.r2.dev

# ─── MIDTRANS (PAYMENT GATEWAY) ─────────────────────────────────────────────
# Kredensial API Midtrans Sandbox/Production untuk kontainer backend.
MIDTRANS_SERVER_KEY="masukkan_server_key_anda"
MIDTRANS_CLIENT_KEY="masukkan_client_key_anda"

# ─── NGROK (WEBHOOK TUNNEL) ─────────────────────────────────────────────────
# Token Ngrok dan endpoint API Ngrok internal Docker (host 'ngrok').
NGROK_AUTHTOKEN=<authtoken>
NGROK_API_URL=http://ngrok:4040/api/tunnels

# ─── JWT & AUTHENTICATION ───────────────────────────────────────────────────
# WAJIB: Ganti dengan string acak, kuat, dan panjang untuk keamanan produksi!
JWT_SECRET=generate_a_very_long_random_string_here_for_production_safety_2026

# ─── FRONTEND & CORS ────────────────────────────────────────────────────────
# Domain tempat aplikasi web diakses oleh pengguna umum.
FRONTEND_URL=https://sotto.id

# ─── SYNERGY RECOMMENDATION ENGINE ──────────────────────────────────────────
# Hyperparameter untuk algoritma pemeringkatan feed rekomendasi Sotto.
SYNERGY_ALPHA=0.6
SYNERGY_BETA=0.1
SYNERGY_GAMMA=0.3
SYNERGY_LAMBDA_G=0.5
SYNERGY_LAMBDA_T=0.0577
SYNERGY_FRESHNESS_BOOST=0.5
SYNERGY_FRESHNESS_DECAY=0.3466

# ─── CLOUDFLARE TUNNEL ──────────────────────────────────────────────────────
# Token Cloudflare Tunnel jika Anda ingin mempublikasikan service secara live.
TUNNEL_TOKEN=

# ─── DOCKER DEPLOYMENT ──────────────────────────────────────────────────────
# Konfigurasi target repositori dan versi tag yang ingin dideploy di VPS.
DOCKER_REGISTRY_USER=untacorp
IMAGE_TAG=latest
