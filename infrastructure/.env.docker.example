# ─── DATABASE (POSTGRESQL) ──────────────────────────────────────────────────
# Kredensial PostgreSQL untuk kontainer Docker.
# DATABASE_URL menggunakan host 'postgres' (nama service di docker-compose).
POSTGRES_USER=platform_admin
POSTGRES_PASSWORD=supersecret_dev_password
POSTGRES_DB=sotto_platform_db
DATABASE_URL="postgresql://platform_admin:supersecret_dev_password@postgres:5432/sotto_platform_db?schema=public"

# ─── SCYLLADB ───────────────────────────────────────────────────────────────
# Alamat contact points dan keyspace ScyllaDB di dalam jaringan Docker.
SCYLLA_CONTACT_POINTS=scylladb:9042
SCYLLA_KEYSPACE=sotto
SCYLLA_DATACENTER=datacenter1

# ─── REDIS ──────────────────────────────────────────────────────────────────
# URL koneksi Redis di dalam jaringan Docker (host 'redis').
REDIS_URL=redis://redis:6379

# ─── OBJECT STORAGE (MINIO / CLOUDFLARE R2) ─────────────────────────────────
# Konfigurasi S3-compatible Object Storage di tingkat Docker (Cloudflare R2 atau MinIO).
# Contoh konfigurasi di bawah menggunakan Cloudflare R2:
MINIO_ENDPOINT=your_cloudflare_account_id.r2.cloudflarestorage.com
MINIO_PORT=
MINIO_USE_SSL=true
MINIO_REGION=auto
MINIO_ACCESS_KEY=your_r2_s3_api_access_key
MINIO_SECRET_KEY=your_r2_s3_api_secret_key
MINIO_BUCKET_PUBLIC=sotto-public-assets
MINIO_BUCKET_PRIVATE=sotto-private-assets

# Alamat URL akses publik ke aset.
# - Cloudflare R2: https://cdn.sotto.auttomus.xyz (atau subdomain R2.dev Anda)
MINIO_PUBLIC_URL=https://cloudflare-subdomain_id.r2.r2.dev
VITE_MINIO_PUBLIC_URL=https://cloudflare-subdomain_id.r2.r2.dev

# ─── MIDTRANS (PAYMENT GATEWAY) ─────────────────────────────────────────────
# Kredensial API Midtrans Sandbox untuk kontainer backend.
MIDTRANS_SERVER_KEY="masukkan_server_key_anda"
MIDTRANS_CLIENT_KEY="masukkan_client_key_anda"

# ─── NGROK (WEBHOOK TUNNEL) ─────────────────────────────────────────────────
# Token Ngrok dan endpoint API Ngrok internal Docker (host 'ngrok').
NGROK_AUTHTOKEN=<authtoken>
NGROK_API_URL=http://ngrok:4040/api/tunnels

# ─── JWT & AUTHENTICATION ───────────────────────────────────────────────────
# Kunci rahasia untuk tanda tangan digital JSON Web Token.
JWT_SECRET=sotto_super_secret_key_2026

# ─── FRONTEND & CORS ────────────────────────────────────────────────────────
# Domain asal aplikasi frontend. Di dalam Docker, dilayani via Nginx port 80.
FRONTEND_URL=http://localhost

# ─── SYNERGY RECOMMENDATION ENGINE ──────────────────────────────────────────
# Hyperparameter untuk algoritma pemeringkatan feed rekomendasi Sotto.
SYNERGY_ALPHA=0.6
SYNERGY_BETA=0.1
SYNERGY_GAMMA=0.3
SYNERGY_LAMBDA_G=0.5
SYNERGY_LAMBDA_T=0.0577
SYNERGY_FRESHNESS_BOOST=0.5
SYNERGY_FRESHNESS_DECAY=0.3466

# ─── CLOUDFLARE TUNNEL ──────────────────────────────────────────────────────
# Token Cloudflare Tunnel jika Anda ingin mempublikasikan service secara live.
TUNNEL_TOKEN=