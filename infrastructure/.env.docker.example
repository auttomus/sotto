# ─── DATABASE (POSTGRESQL) ──────────────────────────
POSTGRES_USER=platform_admin
POSTGRES_PASSWORD=supersecret_dev_password
POSTGRES_DB=sotto_platform_db
# URL untuk Prisma di dalam Docker (service name as host)
DATABASE_URL="postgresql://platform_admin:supersecret_dev_password@postgres:5432/sotto_platform_db?schema=public"

# ─── SCYLLADB ──────────────────────────────────────
SCYLLA_CONTACT_POINTS=scylladb:9042
SCYLLA_KEYSPACE=sotto
SCYLLA_DATACENTER=datacenter1

# ─── REDIS ──────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── CLOUDFLARE R2 (OBJECT STORAGE) ─────────────────
# Menggunakan Endpoint Cloudflare R2 Anda
MINIO_ENDPOINT=your_cloudflare_account_id.r2.cloudflarestorage.com
# Port dikosongkan karena menggunakan HTTPS standar
MINIO_PORT=
MINIO_USE_SSL=true

# Masukkan Kredensial S3 API R2 Anda
MINIO_ACCESS_KEY=your_r2_s3_api_access_key
MINIO_SECRET_KEY=your_r2_s3_api_secret_key

# Nama bucket Anda di Cloudflare R2
MINIO_BUCKET_PUBLIC=sotto-public-assets
MINIO_BUCKET_PRIVATE=sotto-private-assets

# Subdomain R2.dev publik Anda yang sudah aktif (Ini CDN-nya!)
MINIO_PUBLIC_URL=cloudflare-subdomain_id.r2.r2.dev

# ==========================================
# Midtrans
# ==========================================

MIDTRANS_SERVER_KEY="masukkan_server_key_anda"
MIDTRANS_CLIENT_KEY="masukkan_client_key_anda"

# ─── NGROK (PUBLIC URL TUNNEL) ──────────────────────
# Dapatkan token Anda dari: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=<authtoken>

# ─── JWT & AUTH ─────────────────────────────────────
JWT_SECRET=sotto_super_secret_key_2026

# ─── FRONTEND & CORS ────────────────────────────────
# Di dalam Docker, frontend diakses via Nginx di port 80
FRONTEND_URL=http://localhost

# ─── SYNERGY ENGINE HYPERPARAMETERS ─────────────────
# Konfigurasi parameter mesin rekomendasi Sotto
SYNERGY_ALPHA=0.6
SYNERGY_BETA=0.1
SYNERGY_GAMMA=0.3
SYNERGY_LAMBDA_G=0.5
SYNERGY_LAMBDA_T=0.0288

# ─── CLOUDFLARE TUNNEL ──────────────────────────────
TUNNEL_TOKEN=